{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/static/(.*)",
      "destination": "/turbo/static/$1"
    },
    {
      "source": "/",
      "destination": "/landing.html"
    },
    {
      "source": "/login",
      "destination": "/landing.html"
    },
    {
      "source": "/signup",
      "destination": "/landing.html"
    }
  ]
}
